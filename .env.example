# ============================================================================
# 환경변수 템플릿
# ----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 복사해서 .env 로 이름 변경
#   2) 아래 값들 채움
#   3) .env 는 .gitignore에 포함돼 있어 커밋되지 않음
# ============================================================================

# ─── 학과 vLLM 프록시 (필수) ───────────────────────────────
# 팀 API 키. 담당자 또는 팀장에게 문의.
LLM_API_KEY=sk-vllm-xxxxxxxxxxxxxxxxxxxxxxxx

# 기본값 쓰면 아래 주석 그대로 둬도 됨
# LLM_BASE_URL=http://cellm.gachon.ac.kr:8000/v1
# LLM_TEXT_MODEL=text
# LLM_VISION_MODEL=vision
# LLM_EMBEDDING_MODEL=embedding
# LLM_TIMEOUT=60

# ─── 데이터셋 경로 (선택) ─────────────────────────────────
# 원본 DXF 데이터셋 위치 (기본: 프로젝트 상위 폴더의 "데이터셋1-dxf/dxf")
# EXTERNAL_DATASET_DIR=/path/to/your/dxf/folder

# ─── MLOps / 서빙 (선택) ──────────────────────────────────
# MLOPS_DB_PATH=mlops.db
# SERVING_HOST=0.0.0.0
# SERVING_PORT=8001

# ─── 추론 디바이스 (기본 cpu, 학과 서버 규정 준수) ─────────
# INFERENCE_DEVICE=cpu
